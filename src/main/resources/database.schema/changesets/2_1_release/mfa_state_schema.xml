<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <!--
        Release 2.1 – MFA stateless multi-pod support.

        Adds columns to authorization_security_context so that the MFA pending-authentication
        token and the single-use MFA-verified flag are stored in the shared database instead of
        the in-memory HttpSession.  This makes the MFA flow pod-affinity-free.

        Also persists the account ID and the per-user `mfaRequired` override carried on the
        authenticated CustomUserPwdAuthenticationToken, so they survive the DB round-trip and are
        available to MfaChallengeFilter on the subsequent /oauth2/authorize request (otherwise the
        values were lost on reload and CONDITIONAL per-user MFA / account-based step-up never
        triggered).
    -->
    <changeSet id="mfa-pending-columns-to-authorization-security-context" author="HarmanAutoMFA">
        <addColumn tableName="authorization_security_context">
            <!-- Username whose password-auth passed but MFA not yet verified. NULL = no pending MFA. -->
            <column name="MFA_PENDING_USERNAME" type="${STRING_SMALL}"/>
            <!-- Comma-separated GrantedAuthority strings for the pending user. -->
            <column name="MFA_PENDING_AUTHORITIES" type="${STRING_BIG}"/>
            <!-- Resolved tenant ID stored alongside the pending token. -->
            <column name="MFA_TENANT" type="${STRING_SMALL}"/>
            <!-- Single-use flag: set after MFA completes, consumed by MfaChallengeFilter on the
                 very next /oauth2/authorize request to prevent re-interception. -->
            <column name="MFA_VERIFIED_ONCE" type="BOOLEAN" defaultValueBoolean="false"/>
            <!-- Account ID sourced from the user-management record (carried on the token). -->
            <column name="ACCOUNT_ID" type="${STRING_SMALL}"/>
            <!-- Per-user MFA override (mfaRequired user attribute). NULL = no per-user override. -->
            <column name="MFA_REQUIRED" type="BOOLEAN"/>
        </addColumn>
    </changeSet>

    <!--
        Per-user recovery flow state.

        Stores the rate-limit cooldown timestamp and the email-recovery-key-verified flag so
        that the recovery flow works correctly across pods (no HttpSession required).
    -->
    <changeSet id="create-mfa-flow-state-table" author="HarmanAutoMFA">
        <createTable tableName="mfa_flow_state">
            <column name="USERNAME" type="${STRING_SMALL}">
                <constraints nullable="false"/>
            </column>
            <!-- Epoch-millisecond timestamp of the last recovery-email send (for rate-limiting). -->
            <column name="RECOVERY_SENT_AT" type="${DATE_TIME_TZ}"/>
            <!-- True after the email recovery key has been verified; gates the backup-code step. -->
            <column name="RECOVERY_EMAIL_VERIFIED" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_DATE" type="${DATE_TIME_TZ}" defaultValueComputed="${SYSTEM_DATETIME}">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_DATE" type="${DATE_TIME_TZ}" defaultValueComputed="${SYSTEM_DATETIME}">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="mfa_flow_state"
                       columnNames="USERNAME"
                       constraintName="PK_MFA_FLOW_STATE"/>
    </changeSet>

</databaseChangeLog>
