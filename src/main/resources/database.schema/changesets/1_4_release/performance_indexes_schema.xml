<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="create-index-authorization-principal-name" author="System">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_authorization_principal_name" tableName="authorization"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_authorization_principal_name" tableName="authorization">
            <column name="principal_name"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_authorization_principal_name" tableName="authorization"/>
        </rollback>
    </changeSet>

    <changeSet id="create-index-authorization-grant-type" author="System">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_authorization_grant_type" tableName="authorization"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_authorization_grant_type" tableName="authorization">
            <column name="authorization_grant_type"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_authorization_grant_type" tableName="authorization"/>
        </rollback>
    </changeSet>

    <changeSet id="create-index-auth-sec-ctx-principal" author="System">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_auth_sec_ctx_principal" tableName="authorization_security_context"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_auth_sec_ctx_principal" tableName="authorization_security_context">
            <column name="principal"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_auth_sec_ctx_principal" tableName="authorization_security_context"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
